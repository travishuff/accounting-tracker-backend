{
  "name": "banana-backend",
  "version": "1.0.0",
  "description": "Simple banana inventory backend",
  "main": "dist/index.js",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "tsc",
    "start": "bun run build && bun dist/index.js",
    "dev": "bun --watch src/index.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "tsc -p tsconfig.test.json && bun test src/test"
  },
  "author": "",
  "license": "ISC",
  "engines": {
    "bun": ">=1.3.10"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/bun": "^1.3.14",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.0.2",
    "globals": "^15.14.0",
    "prettier": "^3.5.2",
    "typescript": "^5.8.2"
  }
}
